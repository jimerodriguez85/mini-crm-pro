{
  "name": "mini-crm-backend",
  "version": "2.0.0",
  "scripts": {
    "dev": "npx prisma generate && node --watch src/app.js",
    "start": "node src/app.js",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma db push --force-reset && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "prisma": "^5.9.1"
  }
}
